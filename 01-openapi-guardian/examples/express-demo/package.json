{
  "name": "openapi-guardian-express-demo",
  "version": "0.1.0",
  "private": true,
  "description": "Demo project for testing duolakit/openapi-guardian",
  "type": "module",
  "scripts": {
    "dev": "tsx watch server.ts",
    "start": "tsx server.ts",
    "api:types": "openapi-typescript openapi.yaml -o types/api.d.ts",
    "api:check": "echo 'Open Claude Code and run /openapi-check'",
    "api:sync":  "echo 'Open Claude Code and run /openapi-sync'"
  },
  "dependencies": {
    "express": "^4.21.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "openapi-typescript": "^7.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
